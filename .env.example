# ============================================================
# NAIJA PREDICT — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Supabase ---
# Find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY   # Server-only. Never expose to client.

# --- Flutterwave ---
# Find these in your Flutterwave dashboard: Settings → API
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_ENCRYPTION_KEY=YOUR_FLUTTERWAVE_ENCRYPTION_KEY
# Webhook verification hash — set this in Flutterwave Dashboard → Webhooks
FLUTTERWAVE_WEBHOOK_HASH=YOUR_CUSTOM_WEBHOOK_VERIFICATION_HASH

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Change to your production URL when deployed
NEXT_PUBLIC_APP_NAME=NaijaPredict

# --- Oracle API (Sports Data) ---
# Football-Data.org free tier API key
FOOTBALL_DATA_API_KEY=YOUR_FOOTBALL_DATA_ORG_API_KEY
